.env yah file mujhe direct do copy pest format mein

# ==== Telegram Bot ====
BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# ==== Neon DB (PostgreSQL) — structured data: users, likes, follows ====
# Neon dashboard > Connection string (use the "pooled connection" one)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.neon.tech/neondb?sslmode=require

# ==== MongoDB — flexible data: messages (text/voice/audio), reports, admin logs ====
# MongoDB Atlas > Connect > Drivers > copy the connection string (include a db name)
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/telegram_social_bot?retryWrites=true&w=majority

# ==== Admin ====
# Your personal numeric Telegram user id (get it from @userinfobot)
ADMIN_ID=123456789

# ==== Private storage channel ====
# Create a private channel, add the bot as admin, then put the channel id here.
# Channel ids look like -100xxxxxxxxxx
PRIVATE_CHANNEL_ID=-1001234567890

# ==== Deployment (Render) ====
# Full public URL Render gives your service, used for webhook mode.
WEBHOOK_URL=https://your-app.onrender.com
PORT=3000

# Set to "webhook" on Render, "polling" for local development
RUN_MODE=webhook

NODE_ENV=production
