# ==== Main Telegram Bot (also doubles as the restricted Admin Bot) ====
BOT_TOKEN=123456789:AAExampleTokenFromBotFather

# ==== Upload/streaming pool — up to 5 extra bots for round-robin rotation ====
# Optional, but recommended in production to avoid per-bot rate limits.
BOT_TOKEN_2=
BOT_TOKEN_3=
BOT_TOKEN_4=
BOT_TOKEN_5=
BOT_TOKEN_6=

# ==== Neon DB (PostgreSQL) — users, posts, stories, stickers, DMs, reports ====
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.neon.tech/neondb?sslmode=require

# ==== MongoDB — follows, likes, shares ====
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/echo_social?retryWrites=true&w=majority

# ==== Admin ====
# Your personal numeric Telegram user id (get it from @userinfobot).
# All /admin commands are silently ignored for anyone else.
ADMIN_TELEGRAM_ID=123456789

# The web account with this username automatically gets admin rights
# (is_admin = true) the moment it registers or logs in — this is what
# unlocks admin.html (the web Admin Dashboard) for you.
ADMIN_USERNAME=raj_dev_01

# ==== Private storage channel ====
# Create a private channel, add ALL bots (main + pool) as admins, then put the channel id here.
PRIVATE_CHANNEL_ID=-1001234567890

# ==== Deployment ====
WEBHOOK_URL=https://your-app.onrender.com
PORT=3000

# "webhook" on Render, "polling" for local development
RUN_MODE=webhook

NODE_ENV=production
